{
  "expo": {
    "name": "spendwise-ai-mobile",
    "slug": "spendwise-ai-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "spendwiseaimobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
  "adaptiveIcon": {
    "foregroundImage": "./assets/images/adaptive-icon.png",
    "backgroundColor": "#E6F4FE"
  },
  "edgeToEdgeEnabled": true,
  "softwareKeyboardLayoutMode": "pan",
  "package": "com.anonymous.spendwiseaimobile"
},
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
  "expo-router",
  [
    "expo-splash-screen",
    {
      "image": "./assets/images/splash-icon.png",
      "imageWidth": 200,
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    }
  ],
  [
    "expo-image-picker",
    {
      "photosPermission": "Allow SpendWise to access your photos.",
      "cameraPermission": "Allow SpendWise to use your camera."
    }
  ]
],
  

    "experiments": {
      "typedRoutes": false,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "df5de107-2dc9-4f62-b345-61043a363dd8"
      }
    }
  }
}


